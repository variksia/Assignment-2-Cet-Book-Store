@model IEnumerable<CetStudentBook.Models.CartItem>

@{
    ViewData["Title"] = "Shopping Cart";
}

<h1> Shopping Cart</h1>

@if (!Model.Any())
{
    <div class="alert alert-info">
        Your cart is empty. <a asp-controller="Books" asp-action="Index">Browse books</a> to add items.
    </div>
}
else
{
    <table class="table table-hover">
        <thead>
            <tr>
                <th>Product Name</th>
                <th>Unit Price</th>
                <th>Quantity</th>
                <th>Subtotal</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Book!.Name</td>
                    <td>@item.Book.Price.ToString("C")</td>
                    <td>
                        <form asp-action="UpdateQuantity" method="post" style="display:inline;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="cartItemId" value="@item.Id" />
                            <div class="input-group" style="width: 150px;">
                                <input type="number" name="quantity" value="@item.Quantity" min="1" max="100" class="form-control form-control-sm" />
                                <button type="submit" class="btn btn-sm btn-outline-primary">Update</button>
                            </div>
                        </form>
                    </td>
                    <td>@((item.Book.Price * item.Quantity).ToString("C"))</td>
                    <td>
                        <form asp-action="RemoveFromCart" method="post" style="display:inline;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="cartItemId" value="@item.Id" />
                            <button type="submit" class="btn btn-sm btn-danger">Remove</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
        <tfoot>
            <tr>
                <td colspan="3" class="text-end"><strong>Total:</strong></td>
                <td><strong>@ViewBag.TotalPrice.ToString("C")</strong></td>
                <td></td>
            </tr>
        </tfoot>
    </table>

    <div class="d-flex justify-content-between">
        <a asp-controller="Books" asp-action="Index" class="btn btn-secondary">Continue Shopping</a>
        <form asp-action="Purchase" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-success btn-lg">Buy Now</button>
        </form>
    </div>
}
